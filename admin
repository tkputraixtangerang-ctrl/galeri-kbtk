<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Galeri - KB-TK Putra IX</title>
<link href="https://fonts.googleapis.com/css2?family=Bubblegum+Sans&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --purple: #7B2D8B;
    --purple-light: #F3E8FF;
    --blue: #2E74B5;
    --green: #107C41;
    --red: #E53935;
    --yellow: #F59E0B;
    --bg: #FDF4FF;
    --card: #FFFFFF;
    --text: #1A1A2E;
    --muted: #6B7280;
    --border: #E5E7EB;
    --radius: 16px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Nunito', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }
  
  /* LOGIN */
  #login-screen {
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh;
    background: radial-gradient(ellipse at 30% 30%, #FFE066 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, #C084FC 0%, transparent 50%),
                radial-gradient(ellipse at 10% 80%, #86EFAC 0%, transparent 40%),
                #FDF4FF;
  }
  .login-card {
    background: white; border-radius: 24px; padding: 40px; width: 360px;
    box-shadow: 0 20px 60px rgba(123,45,139,0.15);
    text-align: center;
  }
  .login-logo { font-family: 'Bubblegum Sans', cursive; font-size: 2rem; color: var(--purple); margin-bottom: 8px; }
  .login-sub { color: var(--muted); font-size: 0.9rem; margin-bottom: 28px; }
  .login-card input {
    width: 100%; padding: 12px 16px; border: 2px solid var(--border);
    border-radius: 12px; font-family: 'Nunito', sans-serif; font-size: 1rem;
    margin-bottom: 12px; outline: none; transition: border-color 0.2s;
  }
  .login-card input:focus { border-color: var(--purple); }
  .btn-login {
    width: 100%; padding: 14px; background: var(--purple); color: white;
    border: none; border-radius: 12px; font-family: 'Nunito', sans-serif;
    font-size: 1rem; font-weight: 700; cursor: pointer; transition: background 0.2s;
  }
  .btn-login:hover { background: #6B1F7A; }
  .login-error { color: var(--red); font-size: 0.85rem; margin-top: 8px; display: none; }

  /* MAIN APP */
  #app { display: none; }
  
  header {
    background: var(--purple);
    padding: 16px 24px;
    display: flex; align-items: center; justify-content: space-between;
    box-shadow: 0 4px 20px rgba(123,45,139,0.3);
  }
  .header-title { font-family: 'Bubblegum Sans', cursive; color: white; font-size: 1.4rem; }
  .header-sub { color: rgba(255,255,255,0.7); font-size: 0.8rem; }
  .btn-logout { background: rgba(255,255,255,0.15); color: white; border: none; border-radius: 8px; padding: 8px 16px; cursor: pointer; font-family: 'Nunito', sans-serif; font-weight: 700; }
  .btn-logout:hover { background: rgba(255,255,255,0.25); }

  .container { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }

  /* TABS */
  .tabs { display: flex; gap: 8px; margin-bottom: 24px; background: white; padding: 6px; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .tab { flex: 1; padding: 10px; text-align: center; border-radius: 10px; border: none; background: transparent; font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 0.9rem; cursor: pointer; color: var(--muted); transition: all 0.2s; }
  .tab.active { background: var(--purple); color: white; }

  /* CARDS */
  .card { background: var(--card); border-radius: var(--radius); padding: 24px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); margin-bottom: 20px; }
  .card-title { font-family: 'Bubblegum Sans', cursive; font-size: 1.2rem; color: var(--purple); margin-bottom: 16px; }

  /* FORM */
  .form-group { margin-bottom: 16px; }
  label { display: block; font-weight: 700; font-size: 0.85rem; color: var(--text); margin-bottom: 6px; }
  input[type="text"], textarea, select {
    width: 100%; padding: 12px 16px; border: 2px solid var(--border);
    border-radius: 12px; font-family: 'Nunito', sans-serif; font-size: 0.95rem;
    outline: none; transition: border-color 0.2s; background: white; color: var(--text);
  }
  input[type="text"]:focus, textarea:focus, select:focus { border-color: var(--purple); }
  textarea { resize: vertical; min-height: 80px; }

  .preview-box {
    width: 100%; aspect-ratio: 4/3; border-radius: 12px; overflow: hidden;
    background: #F3F4F6; border: 2px dashed var(--border);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px; position: relative;
  }
  .preview-box img { width: 100%; height: 100%; object-fit: cover; display: none; }
  .preview-placeholder { text-align: center; color: var(--muted); }
  .preview-placeholder span { font-size: 2rem; display: block; margin-bottom: 8px; }

  .btn { padding: 12px 24px; border-radius: 12px; border: none; font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: all 0.2s; }
  .btn-primary { background: var(--purple); color: white; }
  .btn-primary:hover { background: #6B1F7A; transform: translateY(-1px); }
  .btn-primary:disabled { background: #C4B5D4; cursor: not-allowed; transform: none; }
  .btn-danger { background: var(--red); color: white; }
  .btn-danger:hover { background: #C62828; }
  .btn-edit { background: var(--blue); color: white; }
  .btn-edit:hover { background: #1A5C9A; }
  .btn-sm { padding: 6px 14px; font-size: 0.8rem; border-radius: 8px; }
  .btn-full { width: 100%; }

  /* PHOTO LIST */
  .photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
  .photo-card {
    background: white; border-radius: 14px; overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.08); transition: transform 0.2s;
  }
  .photo-card:hover { transform: translateY(-3px); }
  .photo-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .photo-card-info { padding: 12px; }
  .photo-card-title { font-weight: 700; font-size: 0.9rem; color: var(--text); margin-bottom: 4px; }
  .photo-card-cat { display: inline-block; padding: 2px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; margin-bottom: 10px; }
  .cat-aktivitas { background: #FEF3C7; color: #92400E; }
  .cat-fieldtrip { background: #D1FAE5; color: #065F46; }
  .cat-lomba { background: #FCE7F3; color: #9D174D; }
  .cat-keagamaan { background: #DBEAFE; color: #1E40AF; }
  .photo-card-actions { display: flex; gap: 6px; }

  /* STATS */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 20px; }
  .stat-card { background: white; border-radius: 12px; padding: 16px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
  .stat-num { font-family: 'Bubblegum Sans', cursive; font-size: 2rem; }
  .stat-label { font-size: 0.75rem; color: var(--muted); font-weight: 700; }

  /* ALERT */
  .alert { padding: 12px 16px; border-radius: 10px; font-size: 0.9rem; font-weight: 600; margin-bottom: 16px; display: none; }
  .alert-success { background: #D1FAE5; color: #065F46; border: 1px solid #A7F3D0; }
  .alert-error { background: #FEE2E2; color: #991B1B; border: 1px solid #FECACA; }
  .alert-info { background: #DBEAFE; color: #1E40AF; border: 1px solid #BFDBFE; }

  /* SETUP GUIDE */
  .setup-step { display: flex; gap: 16px; align-items: flex-start; margin-bottom: 20px; padding: 16px; background: var(--purple-light); border-radius: 12px; }
  .setup-num { width: 36px; height: 36px; background: var(--purple); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; flex-shrink: 0; }
  .setup-content h4 { font-weight: 800; margin-bottom: 4px; color: var(--purple); }
  .setup-content p { font-size: 0.9rem; color: var(--text); }
  .code-box { background: #1E1E2E; color: #CDD6F4; padding: 16px; border-radius: 10px; font-family: monospace; font-size: 0.8rem; white-space: pre-wrap; margin: 10px 0; overflow-x: auto; }

  /* LOADING */
  .loading { text-align: center; padding: 40px; color: var(--muted); }
  .spinner { display: inline-block; width: 36px; height: 36px; border: 4px solid #E5E7EB; border-top-color: var(--purple); border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 12px; }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* MODAL EDIT */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 100; align-items: center; justify-content: center; padding: 20px; }
  .modal-overlay.active { display: flex; }
  .modal { background: white; border-radius: 20px; padding: 28px; width: 100%; max-width: 500px; box-shadow: 0 20px 60px rgba(0,0,0,0.2); }
  .modal h3 { font-family: 'Bubblegum Sans', cursive; color: var(--purple); font-size: 1.3rem; margin-bottom: 20px; }

  .input-with-btn { display: flex; gap: 8px; }
  .input-with-btn input { flex: 1; }

  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .tabs { flex-direction: column; }
  }
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">🏫 KB-TK PUTRA IX</div>
    <div class="login-sub">Panel Admin Galeri — Masuk dulu ya!</div>
    <input type="password" id="pass-input" placeholder="Masukkan password admin" onkeydown="if(event.key==='Enter')doLogin()">
    <button class="btn-login" onclick="doLogin()">Masuk</button>
    <div class="login-error" id="login-error">❌ Password salah, coba lagi.</div>
  </div>
</div>

<!-- MAIN APP -->
<div id="app">
  <header>
    <div>
      <div class="header-title">🎨 Admin Galeri KB-TK Putra IX</div>
      <div class="header-sub">Kelola foto kegiatan sekolah</div>
    </div>
    <button class="btn-logout" onclick="logout()">Keluar</button>
  </header>

  <div class="container">

    <!-- STATUS ALERT -->
    <div class="alert alert-success" id="alert-success"></div>
    <div class="alert alert-error" id="alert-error"></div>
    <div class="alert alert-info" id="alert-info"></div>

    <!-- TABS -->
    <div class="tabs">
      <button class="tab active" onclick="showTab('tab-tambah', this)">➕ Tambah Foto</button>
      <button class="tab" onclick="showTab('tab-kelola', this)">📋 Kelola Foto</button>
      <button class="tab" onclick="showTab('tab-setup', this)">⚙️ Setup Awal</button>
    </div>

    <!-- TAB: TAMBAH FOTO -->
    <div id="tab-tambah">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
        <div class="card">
          <div class="card-title">➕ Tambah Foto Kegiatan Baru</div>

          <div class="form-group">
            <label>Link Google Drive Foto</label>
            <div class="input-with-btn">
              <input type="text" id="drive-link" placeholder="Paste link Google Drive di sini..." oninput="extractAndPreview()">
              <button class="btn btn-edit" onclick="extractAndPreview()">Preview</button>
            </div>
            <small style="color:var(--muted);font-size:0.78rem;margin-top:4px;display:block;">Pastikan foto sudah diatur 'Siapapun yang memiliki link'</small>
          </div>

          <div class="form-group">
            <label>Preview Foto</label>
            <div class="preview-box" id="preview-box">
              <img id="preview-img" src="" alt="">
              <div class="preview-placeholder" id="preview-placeholder">
                <span>🖼️</span>
                <div>Paste link Google Drive di atas</div>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>Judul Kegiatan</label>
            <input type="text" id="input-judul" placeholder="contoh: Lomba Menggambar Hari Merdeka">
          </div>

          <div class="form-group">
            <label>Keterangan Singkat</label>
            <input type="text" id="input-desc" placeholder="contoh: Kreativitas anak-anak bersinar">
          </div>

          <div class="form-group">
            <label>Kategori</label>
            <select id="input-kategori">
              <option value="aktivitas">Aktivitas</option>
              <option value="fieldtrip">Field Trip</option>
              <option value="lomba">Lomba</option>
              <option value="keagamaan">Keagamaan</option>
            </select>
          </div>

          <button class="btn btn-primary btn-full" id="btn-upload" onclick="tambahFoto()">
            ✅ Tambahkan ke Galeri
          </button>
        </div>

        <div>
          <div class="card">
            <div class="card-title">📊 Ringkasan Galeri</div>
            <div class="stats-grid" id="stats-grid">
              <div class="stat-card"><div class="stat-num" style="color:var(--purple)" id="stat-total">-</div><div class="stat-label">Total Foto</div></div>
              <div class="stat-card"><div class="stat-num" style="color:#D97706" id="stat-aktivitas">-</div><div class="stat-label">Aktivitas</div></div>
              <div class="stat-card"><div class="stat-num" style="color:var(--green)" id="stat-fieldtrip">-</div><div class="stat-label">Field Trip</div></div>
              <div class="stat-card"><div class="stat-num" style="color:#DB2777" id="stat-lomba">-</div><div class="stat-label">Lomba</div></div>
            </div>
          </div>

          <div class="card">
            <div class="card-title">💡 Panduan Cepat</div>
            <div style="font-size:0.88rem;line-height:1.8;color:var(--text);">
              <p style="margin-bottom:8px;"><strong>1.</strong> Upload foto ke Google Drive sekolah dulu</p>
              <p style="margin-bottom:8px;"><strong>2.</strong> Klik kanan foto → Bagikan → <em>"Siapapun yang memiliki link"</em></p>
              <p style="margin-bottom:8px;"><strong>3.</strong> Salin tautan → Paste di kolom Link di atas</p>
              <p style="margin-bottom:8px;"><strong>4.</strong> Isi judul, keterangan, pilih kategori</p>
              <p><strong>5.</strong> Klik <strong>"Tambahkan ke Galeri"</strong> — selesai! ✅</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: KELOLA FOTO -->
    <div id="tab-kelola" style="display:none;">
      <div class="card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <div class="card-title" style="margin-bottom:0;">📋 Semua Foto Galeri</div>
          <button class="btn btn-edit btn-sm" onclick="loadPhotos()">🔄 Refresh</button>
        </div>

        <div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
          <button class="btn btn-sm" style="background:#F3F4F6;color:var(--text);" onclick="filterPhotos('semua')">Semua</button>
          <button class="btn btn-sm cat-aktivitas" onclick="filterPhotos('aktivitas')">Aktivitas</button>
          <button class="btn btn-sm cat-fieldtrip" onclick="filterPhotos('fieldtrip')">Field Trip</button>
          <button class="btn btn-sm cat-lomba" onclick="filterPhotos('lomba')">Lomba</button>
          <button class="btn btn-sm cat-keagamaan" onclick="filterPhotos('keagamaan')">Keagamaan</button>
        </div>

        <div id="photo-list">
          <div class="loading">
            <div class="spinner"></div>
            <div>Memuat foto...</div>
          </div>
        </div>
      </div>
    </div>

    <!-- TAB: SETUP -->
    <div id="tab-setup" style="display:none;">
      <div class="card">
        <div class="card-title">⚙️ Setup Awal — Hanya Sekali!</div>
        <p style="margin-bottom:20px;color:var(--muted);font-size:0.9rem;">Ikuti langkah berikut untuk menghubungkan panel admin ini ke Google Sheets sebagai database galeri.</p>

        <div class="setup-step">
          <div class="setup-num">1</div>
          <div class="setup-content">
            <h4>Buat Google Sheet baru</h4>
            <p>Buka <strong>sheets.google.com</strong> → klik "+ Kosong" → beri nama: <strong>Database Galeri KBTK Putra IX</strong></p>
          </div>
        </div>

        <div class="setup-step">
          <div class="setup-num">2</div>
          <div class="setup-content">
            <h4>Buat header di baris pertama Sheet</h4>
            <p>Di baris 1, isi kolom A sampai E dengan teks berikut (masing-masing satu kolom):</p>
            <div class="code-box">A1: id    B1: judul    C1: deskripsi    D1: kategori    E1: tanggal</div>
          </div>
        </div>

        <div class="setup-step">
          <div class="setup-num">3</div>
          <div class="setup-content">
            <h4>Buka Apps Script dari Sheet tersebut</h4>
            <p>Di Google Sheet → klik menu <strong>Ekstensi</strong> → klik <strong>Apps Script</strong> → halaman editor terbuka</p>
          </div>
        </div>

        <div class="setup-step">
          <div class="setup-num">4</div>
          <div class="setup-content">
            <h4>Paste kode ini ke Apps Script</h4>
            <p>Hapus semua kode yang ada, lalu paste kode di bawah ini:</p>
            <div class="code-box" id="apps-script-code">const SHEET_NAME = 'Sheet1';

function doGet(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);
  const data = sheet.getDataRange().getValues();
  const headers = data[0];
  const rows = data.slice(1).map(row => {
    const obj = {};
    headers.forEach((h, i) => obj[h] = row[i]);
    return obj;
  }).filter(r => r.id);
  return ContentService.createTextOutput(JSON.stringify(rows))
    .setMimeType(ContentService.MimeType.JSON);
}

function doPost(e) {
  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(SHEET_NAME);
  const params = JSON.parse(e.postData.contents);
  const action = params.action;
  const data = sheet.getDataRange().getValues();

  if (action === 'add') {
    sheet.appendRow([params.id, params.judul, params.deskripsi, params.kategori, new Date().toLocaleDateString('id-ID')]);
    return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
  }

  if (action === 'delete') {
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === params.id) { sheet.deleteRow(i + 1); break; }
    }
    return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
  }

  if (action === 'edit') {
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === params.id) {
        sheet.getRange(i + 1, 2).setValue(params.judul);
        sheet.getRange(i + 1, 3).setValue(params.deskripsi);
        sheet.getRange(i + 1, 4).setValue(params.kategori);
        break;
      }
    }
    return ContentService.createTextOutput(JSON.stringify({status:'ok'})).setMimeType(ContentService.MimeType.JSON);
  }

  return ContentService.createTextOutput(JSON.stringify({status:'error'})).setMimeType(ContentService.MimeType.JSON);
}</div>
            <button class="btn btn-edit btn-sm" onclick="copyCode()" style="margin-top:8px;">📋 Salin Kode</button>
          </div>
        </div>

        <div class="setup-step">
          <div class="setup-num">5</div>
          <div class="setup-content">
            <h4>Deploy sebagai Web App</h4>
            <p>Di Apps Script → klik <strong>Deploy</strong> (pojok kanan atas) → <strong>New deployment</strong> → pilih type: <strong>Web app</strong> → Execute as: <strong>Me</strong> → Who has access: <strong>Anyone</strong> → klik <strong>Deploy</strong> → Salin URL Web App yang muncul</p>
          </div>
        </div>

        <div class="setup-step">
          <div class="setup-num">6</div>
          <div class="setup-content">
            <h4>Paste URL Web App di bawah ini</h4>
            <p>Setelah dapat URL dari langkah 5, paste di sini lalu klik Simpan:</p>
            <div style="display:flex;gap:8px;margin-top:10px;">
              <input type="text" id="apps-script-url" placeholder="https://script.google.com/macros/s/..." style="flex:1;">
              <button class="btn btn-primary" onclick="saveScriptUrl()">Simpan</button>
            </div>
            <small style="color:var(--muted);font-size:0.78rem;margin-top:6px;display:block;" id="url-saved-msg"></small>
          </div>
        </div>

        <div class="setup-step" style="background:#D1FAE5;">
          <div class="setup-num" style="background:var(--green);">✓</div>
          <div class="setup-content">
            <h4 style="color:var(--green);">Selesai! Panel siap digunakan</h4>
            <p>Setelah URL tersimpan, kembali ke tab <strong>"Tambah Foto"</strong> dan mulai tambahkan foto kegiatan!</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- MODAL EDIT -->
<div class="modal-overlay" id="edit-modal">
  <div class="modal">
    <h3>✏️ Edit Foto</h3>
    <input type="hidden" id="edit-id">
    <div class="form-group">
      <label>Judul Kegiatan</label>
      <input type="text" id="edit-judul" placeholder="Judul kegiatan">
    </div>
    <div class="form-group">
      <label>Keterangan Singkat</label>
      <input type="text" id="edit-desc" placeholder="Keterangan singkat">
    </div>
    <div class="form-group">
      <label>Kategori</label>
      <select id="edit-kategori">
        <option value="aktivitas">Aktivitas</option>
        <option value="fieldtrip">Field Trip</option>
        <option value="lomba">Lomba</option>
        <option value="keagamaan">Keagamaan</option>
      </select>
    </div>
    <div style="display:flex;gap:10px;justify-content:flex-end;">
      <button class="btn" style="background:#F3F4F6;" onclick="closeModal()">Batal</button>
      <button class="btn btn-primary" onclick="simpanEdit()">💾 Simpan Perubahan</button>
    </div>
  </div>
</div>

<script>
// ====== CONFIG ======
const ADMIN_PASSWORD = 'kbtk2025'; // Ganti password di sini
let scriptUrl = localStorage.getItem('kbtk_script_url') || '';
let allPhotos = [];
let currentFilter = 'semua';

// ====== LOGIN ======
function doLogin() {
  const val = document.getElementById('pass-input').value;
  if (val === ADMIN_PASSWORD) {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    checkSetup();
    loadPhotos();
  } else {
    document.getElementById('login-error').style.display = 'block';
    document.getElementById('pass-input').value = '';
    document.getElementById('pass-input').focus();
  }
}

function logout() {
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  document.getElementById('pass-input').value = '';
}

function checkSetup() {
  if (!scriptUrl) {
    showAlert('info', '⚙️ Belum ada URL Apps Script! Buka tab "Setup Awal" untuk menghubungkan ke database.');
  } else {
    document.getElementById('apps-script-url').value = scriptUrl;
    document.getElementById('url-saved-msg').textContent = '✅ URL sudah tersimpan: ' + scriptUrl.substring(0, 50) + '...';
  }
}

// ====== TABS ======
function showTab(id, btn) {
  ['tab-tambah','tab-kelola','tab-setup'].forEach(t => document.getElementById(t).style.display = 'none');
  document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
  document.getElementById(id).style.display = 'block';
  btn.classList.add('active');
  if (id === 'tab-kelola') loadPhotos();
}

// ====== EXTRACT ID DARI LINK DRIVE ======
function extractDriveId(link) {
  const m = link.match(/\/d\/([a-zA-Z0-9_-]{15,})/);
  if (m) return m[1];
  const m2 = link.match(/id=([a-zA-Z0-9_-]{15,})/);
  if (m2) return m2[1];
  return null;
}

function extractAndPreview() {
  const link = document.getElementById('drive-link').value.trim();
  const id = extractDriveId(link);
  const img = document.getElementById('preview-img');
  const placeholder = document.getElementById('preview-placeholder');
  if (id) {
    img.src = `https://drive.google.com/thumbnail?id=${id}&sz=w600`;
    img.style.display = 'block';
    placeholder.style.display = 'none';
    img.onerror = () => {
      img.style.display = 'none';
      placeholder.style.display = 'flex';
      placeholder.innerHTML = '<span>⚠️</span><div>Foto tidak bisa ditampilkan. Pastikan sudah diatur "Siapapun yang memiliki link"</div>';
    };
  } else {
    img.style.display = 'none';
    placeholder.style.display = 'flex';
    placeholder.innerHTML = '<span>🖼️</span><div>Paste link Google Drive di atas</div>';
  }
}

// ====== API CALLS ======
async function apiCall(data) {
  if (!scriptUrl) {
    showAlert('error', '❌ URL Apps Script belum diisi! Buka tab Setup Awal dulu.');
    return null;
  }
  const resp = await fetch(scriptUrl, {
    method: 'POST',
    body: JSON.stringify(data),
    headers: { 'Content-Type': 'text/plain' }
  });
  return resp.json();
}

async function loadPhotos() {
  if (!scriptUrl) {
    document.getElementById('photo-list').innerHTML = '<div class="loading"><div>⚙️ URL Apps Script belum diisi. Buka tab Setup Awal.</div></div>';
    updateStats([]);
    return;
  }
  document.getElementById('photo-list').innerHTML = '<div class="loading"><div class="spinner"></div><div>Memuat foto...</div></div>';
  try {
    const resp = await fetch(scriptUrl + '?t=' + Date.now());
    allPhotos = await resp.json();
    renderPhotos(allPhotos);
    updateStats(allPhotos);
  } catch(e) {
    document.getElementById('photo-list').innerHTML = '<div class="loading">❌ Gagal memuat. Cek koneksi atau URL Apps Script.</div>';
  }
}

function updateStats(photos) {
  document.getElementById('stat-total').textContent = photos.length;
  document.getElementById('stat-aktivitas').textContent = photos.filter(p => p.kategori === 'aktivitas').length;
  document.getElementById('stat-fieldtrip').textContent = photos.filter(p => p.kategori === 'fieldtrip').length;
  document.getElementById('stat-lomba').textContent = photos.filter(p => p.kategori === 'lomba').length;
}

function filterPhotos(cat) {
  currentFilter = cat;
  const filtered = cat === 'semua' ? allPhotos : allPhotos.filter(p => p.kategori === cat);
  renderPhotos(filtered);
}

function renderPhotos(photos) {
  if (!photos.length) {
    document.getElementById('photo-list').innerHTML = '<div class="loading">Belum ada foto di kategori ini.</div>';
    return;
  }
  const catClass = { aktivitas: 'cat-aktivitas', fieldtrip: 'cat-fieldtrip', lomba: 'cat-lomba', keagamaan: 'cat-keagamaan' };
  const catLabel = { aktivitas: 'Aktivitas', fieldtrip: 'Field Trip', lomba: 'Lomba', keagamaan: 'Keagamaan' };
  document.getElementById('photo-list').innerHTML = `
    <div class="photo-grid">
      ${photos.map((p, i) => `
        <div class="photo-card">
          <img src="https://drive.google.com/thumbnail?id=${p.id}&sz=w400" alt="${p.judul}" loading="lazy" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22100%22 height=%22100%22><rect fill=%22%23F3F4F6%22 width=%22100%22 height=%22100%22/><text x=%2250%22 y=%2255%22 text-anchor=%22middle%22 fill=%22%239CA3AF%22>No Image</text></svg>'">
          <div class="photo-card-info">
            <div class="photo-card-title">${p.judul}</div>
            <span class="photo-card-cat ${catClass[p.kategori] || ''}">${catLabel[p.kategori] || p.kategori}</span>
            <div style="font-size:0.78rem;color:var(--muted);margin-bottom:10px;">${p.deskripsi || ''}</div>
            <div class="photo-card-actions">
              <button class="btn btn-edit btn-sm" onclick="openEdit('${p.id}','${escapeQ(p.judul)}','${escapeQ(p.deskripsi)}','${p.kategori}')">✏️ Edit</button>
              <button class="btn btn-danger btn-sm" onclick="hapusFoto('${p.id}','${escapeQ(p.judul)}')">🗑️ Hapus</button>
            </div>
          </div>
        </div>
      `).join('')}
    </div>
  `;
}

function escapeQ(s) { return (s||'').replace(/'/g, "\\'"); }

// ====== TAMBAH FOTO ======
async function tambahFoto() {
  const link = document.getElementById('drive-link').value.trim();
  const id = extractDriveId(link);
  const judul = document.getElementById('input-judul').value.trim();
  const desc = document.getElementById('input-desc').value.trim();
  const kat = document.getElementById('input-kategori').value;

  if (!link) { showAlert('error', '❌ Link Google Drive belum diisi!'); return; }
  if (!id) { showAlert('error', '❌ Link Google Drive tidak valid. Pastikan link dari Google Drive yang benar.'); return; }
  if (!judul) { showAlert('error', '❌ Judul kegiatan belum diisi!'); return; }

  const btn = document.getElementById('btn-upload');
  btn.disabled = true; btn.textContent = '⏳ Menyimpan...';

  const result = await apiCall({ action: 'add', id, judul, deskripsi: desc, kategori: kat });

  btn.disabled = false; btn.textContent = '✅ Tambahkan ke Galeri';

  if (result && result.status === 'ok') {
    showAlert('success', `✅ Foto "${judul}" berhasil ditambahkan ke galeri!`);
    document.getElementById('drive-link').value = '';
    document.getElementById('input-judul').value = '';
    document.getElementById('input-desc').value = '';
    document.getElementById('preview-img').style.display = 'none';
    document.getElementById('preview-placeholder').style.display = 'flex';
    document.getElementById('preview-placeholder').innerHTML = '<span>🖼️</span><div>Paste link Google Drive di atas</div>';
    loadPhotos();
  } else {
    showAlert('error', '❌ Gagal menyimpan. Cek koneksi atau URL Apps Script di tab Setup.');
  }
}

// ====== HAPUS FOTO ======
async function hapusFoto(id, judul) {
  if (!confirm(`Yakin mau hapus foto "${judul}"?`)) return;
  const result = await apiCall({ action: 'delete', id });
  if (result && result.status === 'ok') {
    showAlert('success', `✅ Foto "${judul}" berhasil dihapus.`);
    loadPhotos();
  } else {
    showAlert('error', '❌ Gagal menghapus. Coba lagi.');
  }
}

// ====== EDIT FOTO ======
function openEdit(id, judul, desc, kat) {
  document.getElementById('edit-id').value = id;
  document.getElementById('edit-judul').value = judul;
  document.getElementById('edit-desc').value = desc;
  document.getElementById('edit-kategori').value = kat;
  document.getElementById('edit-modal').classList.add('active');
}

function closeModal() {
  document.getElementById('edit-modal').classList.remove('active');
}

async function simpanEdit() {
  const id = document.getElementById('edit-id').value;
  const judul = document.getElementById('edit-judul').value.trim();
  const desc = document.getElementById('edit-desc').value.trim();
  const kat = document.getElementById('edit-kategori').value;
  if (!judul) { alert('Judul tidak boleh kosong!'); return; }

  const result = await apiCall({ action: 'edit', id, judul, deskripsi: desc, kategori: kat });
  if (result && result.status === 'ok') {
    closeModal();
    showAlert('success', `✅ Foto "${judul}" berhasil diperbarui.`);
    loadPhotos();
  } else {
    showAlert('error', '❌ Gagal menyimpan perubahan.');
  }
}

// ====== SETUP ======
function saveScriptUrl() {
  const url = document.getElementById('apps-script-url').value.trim();
  if (!url.startsWith('https://script.google.com')) {
    alert('URL tidak valid! Harus dimulai dengan https://script.google.com');
    return;
  }
  scriptUrl = url;
  localStorage.setItem('kbtk_script_url', url);
  document.getElementById('url-saved-msg').textContent = '✅ URL berhasil disimpan!';
  showAlert('success', '✅ URL Apps Script berhasil disimpan! Sekarang bisa mulai tambah foto.');
  loadPhotos();
}

function copyCode() {
  const code = document.getElementById('apps-script-code').textContent;
  navigator.clipboard.writeText(code).then(() => alert('✅ Kode berhasil disalin!'));
}

// ====== ALERT ======
function showAlert(type, msg) {
  ['success','error','info'].forEach(t => {
    const el = document.getElementById('alert-' + t);
    el.style.display = 'none';
  });
  const el = document.getElementById('alert-' + type);
  el.textContent = msg;
  el.style.display = 'block';
  setTimeout(() => el.style.display = 'none', 5000);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Close modal on overlay click
document.getElementById('edit-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
</script>
